# 复制为 .env 后填写（.env 已被 gitignore）

TKT_PROVIDER=minimax

# MiniMax Token Plan
MINIMAX_API_KEY=
# MINIMAX_API_BASE=https://www.minimaxi.com

# tkt gc 自动推送（也可 tkt gc --push / --no-push）
# TKT_GC_PUSH=false

# 关闭启动时的版本更新提示
# TKT_NO_UPDATE=1

# OpenAI Compatible（tkt gc / report）
# AI_BASE_URL=https://api.openai.com/v1
# AI_API_KEY=
# AI_MODEL=gpt-4o-mini
# DeepSeek 等不支持 json_schema 时会自动关 structured outputs；也可强制：
# AI_STRUCTURED_OUTPUTS=false
